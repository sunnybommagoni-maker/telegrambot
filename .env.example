# ─── Telegram Bot ────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Admin Telegram User IDs (comma-separated) ───────────────
# Get your ID from @userinfobot on Telegram
ADMIN_IDS=5936922644

# ─── Firebase ─────────────────────────────────────────────────
FIREBASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# ─── Website (Firebase Hosting URL) ──────────────────────────
WEBSITE_BASE_URL=https://your-project.web.app

# ─── Shortlink API ────────────────────────────────────────────
# Provider: linkvertise | exeio | shrinkearn | linkpays
SHORTLINK_PROVIDER=linkvertise
LINKVERTISE_USER_ID=4840981
EXEIO_API_KEY=your_exeio_api_key
SHRINKEARN_API_KEY=your_shrinkearn_api_key
LINKPAYS_API_KEY=your_linkpays_api_key

# ─── Payment Settings ─────────────────────────────────────────
DEPOSIT_AMOUNT=100
MIN_WITHDRAW=200
UPI_ID=7730846362@upi
